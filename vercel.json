{
  "cleanUrls": true,
  "trailingSlash": false,

  "redirects": [
    { "source": "/share", "has": [{"type":"query","key":"m","value":"1"}], "destination": "/share/1", "permanent": false },
    { "source": "/share", "has": [{"type":"query","key":"m","value":"2"}], "destination": "/share/2", "permanent": false },
    { "source": "/share", "has": [{"type":"query","key":"m","value":"3"}], "destination": "/share/3", "permanent": false },
    { "source": "/share", "has": [{"type":"query","key":"m","value":"4"}], "destination": "/share/4", "permanent": false },
    { "source": "/share", "has": [{"type":"query","key":"m","value":"5"}], "destination": "/share/5", "permanent": false },
    { "source": "/share", "has": [{"type":"query","key":"m","value":"6"}], "destination": "/share/6", "permanent": false },
    { "source": "/share", "has": [{"type":"query","key":"m","value":"7"}], "destination": "/share/7", "permanent": false },
    { "source": "/share", "has": [{"type":"query","key":"m","value":"8"}], "destination": "/share/8", "permanent": false },
    { "source": "/share", "has": [{"type":"query","key":"m","value":"9"}], "destination": "/share/9", "permanent": false },
    { "source": "/baby-name-numerology", "destination": "/name-numerology-calculator", "permanent": true }
  ],

  "rewrites": [
    { "source": "/api/capture-lead",          "destination": "/api/capture-lead.js" },
    { "source": "/api/create-order",          "destination": "/api/create-order.js" },
    { "source": "/api/generate-report",       "destination": "/api/generate-report.js" },
    { "source": "/api/validate-promo",        "destination": "/api/validate-promo.js" },
    { "source": "/api/razorpay-webhook",      "destination": "/api/razorpay-webhook.js" },
    { "source": "/api/paypal-create-order",   "destination": "/api/paypal-create-order.js" },
    { "source": "/api/paypal-capture",        "destination": "/api/paypal-capture.js" },
    { "source": "/api/aura",                  "destination": "/api/aura.js" },
    { "source": "/api/health-supabase",       "destination": "/api/health-supabase.js" },
    { "source": "/api/aura/v2/message",       "destination": "/api/aura/v2/message.js" },
    { "source": "/api/aura/v2/me",            "destination": "/api/aura/v2/me.js" },
    { "source": "/api/aura/v2/auth/anonymous", "destination": "/api/aura/v2/auth/anonymous.js" }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)\\.(jpg|jpeg|png|webp|svg|gif|ico|woff2?|ttf|otf|css|js|mjs)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/og/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=21600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
